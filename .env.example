# Cisco Catalyst 9800 WLC (RESTCONF) connection settings. Copy to .env; never commit it.
# The C9800 must have `ip http secure-server`, `restconf`, `aaa new-model` and a
# privilege-15 local user enabled (RESTCONF uses HTTPS Basic auth).
# Suite-wide option: put these in a shared ../.env (one level above the repos) that
# every companion MCP reads - see cml-mcp/.env.example. Precedence: env > repo .env > ../.env.
WLC_URL=https://192.0.2.70
WLC_USERNAME=admin
WLC_PASSWORD=changeme
# Verify the C9800 TLS certificate (labs use the auto-generated self-signed cert).
WLC_VERIFY_SSL=false
# Per-request timeout in seconds (RESTCONF writes to a busy WLC can be slow).
WLC_TIMEOUT=60
# Retries on transient transport failures (connect/read timeouts, resets).
WLC_RETRIES=2
